+    // Subtypes - what caused the error
+    FFMS_ERROR_UNKNOWN = 20,		// unknown error
+    FFMS_ERROR_UNSUPPORTED,			// format or operation is not supported with this binary
+    FFMS_ERROR_FILE_READ,			// cannot read from file
